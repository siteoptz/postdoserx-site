#!/usr/bin/env node

/**
 * Correctness Review Lane
 * 
 * Reviews code for logical correctness, edge cases, and error handling
 * Part of the 5-lane parallel code review system
 */

const fs = require('fs');
const path = require('path');
const { execSync } = require('child_process');

// Analyze code correctness
function analyzeCorrectness() {
    const findings = [];
    const severity = { critical: 0, high: 0, medium: 0, low: 0 };
    
    console.log('🔍 Running Correctness Review...\n');
    
    // 1. Check for error handling patterns
    try {
        const jsFiles = execSync('find . -name "*.js" -not -path "./node_modules/*" -not -path "./.git/*"', 
            { encoding: 'utf8' }).split('\n').filter(f => f.trim());
        
        for (const file of jsFiles) {
            if (!fs.existsSync(file)) continue;
            
            const content = fs.readFileSync(file, 'utf8');
            const lines = content.split('\n');
            
            // Check for try-catch usage
            const tryBlocks = (content.match(/try\s*{/g) || []).length;
            const catchBlocks = (content.match(/catch\s*\(/g) || []).length;
            const asyncFunctions = (content.match(/async\s+function|=\s*async/g) || []).length;
            
            if (asyncFunctions > 0 && tryBlocks === 0) {
                findings.push({
                    severity: 'medium',
                    file: file,
                    line: 'Multiple locations',
                    finding: `${asyncFunctions} async functions without try-catch blocks`,
                    recommendation: 'Add error handling for async operations to prevent unhandled promise rejections'
                });
                severity.medium++;
            }
            
            // Check for null/undefined checks
            const nullChecks = (content.match(/(?:!==?\s*null|null\s*!==?)|(?:!==?\s*undefined|undefined\s*!==?)/g) || []).length;
            const propertyAccess = (content.match(/\.\w+/g) || []).length;
            
            if (propertyAccess > 10 && nullChecks < 3) {
                findings.push({
                    severity: 'medium',
                    file: file,
                    line: 'Multiple locations',
                    finding: 'High property access with minimal null/undefined checks',
                    recommendation: 'Add defensive null checks before property access to prevent runtime errors'
                });
                severity.medium++;
            }
            
            // Check for proper input validation in API endpoints
            if (file.includes('/api/')) {
                const hasValidation = content.includes('validate') || 
                                    content.includes('schema') ||
                                    content.includes('body.') ||
                                    content.includes('req.body') && content.includes('if');
                
                if (!hasValidation) {
                    findings.push({
                        severity: 'high',
                        file: file,
                        line: 'API endpoint',
                        finding: 'API endpoint without apparent input validation',
                        recommendation: 'Add input validation and sanitization for all user inputs'
                    });
                    severity.high++;
                }
            }
            
            // Check for hardcoded values that should be configurable
            const hardcodedUrls = content.match(/https?:\/\/[^\s"']+/g) || [];
            const suspiciousHardcoded = hardcodedUrls.filter(url => 
                !url.includes('localhost') && 
                !url.includes('example.com') &&
                !url.includes('github.com')
            );
            
            if (suspiciousHardcoded.length > 0) {
                findings.push({
                    severity: 'low',
                    file: file,
                    line: 'Multiple locations',
                    finding: `${suspiciousHardcoded.length} hardcoded URLs found`,
                    recommendation: 'Consider moving URLs to environment variables or configuration'
                });
                severity.low++;
            }
            
            // Check for potential race conditions in async code
            lines.forEach((line, index) => {
                if (line.includes('setTimeout') && line.includes('await')) {
                    findings.push({
                        severity: 'medium',
                        file: file,
                        line: index + 1,
                        finding: 'Potential race condition: setTimeout with await',
                        recommendation: 'Review async timing logic to ensure proper execution order'
                    });
                    severity.medium++;
                }
                
                // Check for direct DOM manipulation in what should be server-side code
                if (file.includes('/api/') && (line.includes('document.') || line.includes('window.'))) {
                    findings.push({
                        severity: 'critical',
                        file: file,
                        line: index + 1,
                        finding: 'Server-side code accessing browser globals',
                        recommendation: 'Remove browser-specific code from server-side files'
                    });
                    severity.critical++;
                }
            });
        }
        
    } catch (error) {
        findings.push({
            severity: 'high',
            file: 'review-system',
            line: 'N/A',
            finding: `Error analyzing JavaScript files: ${error.message}`,
            recommendation: 'Fix file access permissions or code review tool configuration'
        });
        severity.high++;
    }
    
    // 2. Check HTML for common correctness issues
    try {
        const htmlFiles = execSync('find . -name "*.html" -not -path "./node_modules/*"', 
            { encoding: 'utf8' }).split('\n').filter(f => f.trim());
        
        for (const file of htmlFiles) {
            if (!fs.existsSync(file)) continue;
            
            const content = fs.readFileSync(file, 'utf8');
            
            // Check for missing alt attributes on images
            const imgTags = content.match(/<img[^>]*>/gi) || [];
            const imagesWithoutAlt = imgTags.filter(img => !img.includes('alt='));
            
            if (imagesWithoutAlt.length > 0) {
                findings.push({
                    severity: 'medium',
                    file: file,
                    line: 'Multiple locations',
                    finding: `${imagesWithoutAlt.length} images without alt attributes`,
                    recommendation: 'Add alt attributes to all images for accessibility'
                });
                severity.medium++;
            }
            
            // Check for missing form validation
            const forms = content.match(/<form[^>]*>/gi) || [];
            const hasClientValidation = content.includes('required') || content.includes('pattern=');
            
            if (forms.length > 0 && !hasClientValidation) {
                findings.push({
                    severity: 'medium',
                    file: file,
                    line: 'Form elements',
                    finding: 'Forms without client-side validation attributes',
                    recommendation: 'Add HTML5 validation attributes (required, pattern, etc.)'
                });
                severity.medium++;
            }
        }
        
    } catch (error) {
        console.warn(`Warning: Could not analyze HTML files: ${error.message}`);
    }
    
    return {
        reviewType: 'correctness',
        findings,
        severity,
        summary: {
            totalIssues: findings.length,
            criticalIssues: severity.critical,
            highIssues: severity.high,
            mediumIssues: severity.medium,
            lowIssues: severity.low
        }
    };
}

// Generate correctness review report
function generateReport() {
    const analysis = analyzeCorrectness();
    
    console.log('📊 CORRECTNESS REVIEW RESULTS');
    console.log('=' .repeat(50));
    console.log(`Total Issues: ${analysis.summary.totalIssues}`);
    console.log(`Critical: ${analysis.summary.criticalIssues}`);
    console.log(`High: ${analysis.summary.highIssues}`);
    console.log(`Medium: ${analysis.summary.mediumIssues}`);
    console.log(`Low: ${analysis.summary.lowIssues}\n`);
    
    if (analysis.findings.length === 0) {
        console.log('✅ No correctness issues found!\n');
    } else {
        console.log('🔍 DETAILED FINDINGS:\n');
        
        // Group by severity
        const grouped = {
            critical: analysis.findings.filter(f => f.severity === 'critical'),
            high: analysis.findings.filter(f => f.severity === 'high'),
            medium: analysis.findings.filter(f => f.severity === 'medium'),
            low: analysis.findings.filter(f => f.severity === 'low')
        };
        
        ['critical', 'high', 'medium', 'low'].forEach(sev => {
            if (grouped[sev].length > 0) {
                const icon = sev === 'critical' ? '🚨' : sev === 'high' ? '⚠️' : sev === 'medium' ? '💡' : 'ℹ️';
                console.log(`${icon} ${sev.toUpperCase()} (${grouped[sev].length} issues):`);
                
                grouped[sev].forEach((finding, index) => {
                    console.log(`\n${index + 1}. ${finding.finding}`);
                    console.log(`   File: ${finding.file}:${finding.line}`);
                    console.log(`   Recommendation: ${finding.recommendation}`);
                });
                console.log('');
            }
        });
    }
    
    return analysis;
}

// Main execution
function main() {
    const command = process.argv[2];
    
    switch (command) {
        case '--json':
            const analysis = analyzeCorrectness();
            console.log(JSON.stringify(analysis, null, 2));
            break;
            
        default:
            generateReport();
            break;
    }
}

// Only run if this file is executed directly
if (require.main === module) {
    main();
}

module.exports = {
    analyzeCorrectness,
    generateReport
};