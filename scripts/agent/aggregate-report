#!/usr/bin/env node

/**
 * Aggregate Report Generator
 * 
 * Combines results from all 5 parallel code review lanes
 * Part of the 5-lane parallel code review system
 */

const fs = require('fs');
const path = require('path');
const { execSync } = require('child_process');

// Import all review modules
const { analyzeCorrectness } = require('./review-correctness');
const { analyzeArchitecture } = require('./review-architecture');
const { analyzeStyleRules } = require('./review-style-rules');
const { analyzePerformanceReliability } = require('./review-performance-reliability');
const { analyzeRegressionHistory } = require('./review-regression-history');

// Run all review lanes in parallel (simulated)
async function runAllReviews(args = []) {
    console.log('🚀 Starting 5-Lane Parallel Code Review System...\n');
    
    const reviews = {
        correctness: null,
        architecture: null,
        styleRules: null,
        performanceReliability: null,
        regressionHistory: null
    };
    
    const startTime = Date.now();
    
    try {
        // Run all reviews
        console.log('🔍 Running correctness review...');
        reviews.correctness = analyzeCorrectness();
        
        console.log('🏗️ Running architecture review...');
        reviews.architecture = analyzeArchitecture(args);
        
        console.log('🎨 Running style rules review...');
        reviews.styleRules = analyzeStyleRules();
        
        console.log('⚡ Running performance & reliability review...');
        reviews.performanceReliability = analyzePerformanceReliability();
        
        console.log('🔄 Running regression & history review...');
        reviews.regressionHistory = analyzeRegressionHistory(args);
        
        const endTime = Date.now();
        const duration = ((endTime - startTime) / 1000).toFixed(2);
        
        console.log(`\n✅ All reviews completed in ${duration} seconds\n`);
        
    } catch (error) {
        console.error(`❌ Error running reviews: ${error.message}`);
        process.exit(1);
    }
    
    return reviews;
}

// Generate aggregate report
function generateAggregateReport(reviews, options = {}) {
    const { saveToFile = true, format = 'console' } = options;
    
    // Combine all findings
    const allFindings = [];
    const reviewSummaries = {};
    const totalSeverity = { critical: 0, high: 0, medium: 0, low: 0 };
    
    // Process each review
    Object.entries(reviews).forEach(([reviewType, analysis]) => {
        if (!analysis || !analysis.findings) return;
        
        // Add review type to each finding
        const findingsWithType = analysis.findings.map(finding => ({
            ...finding,
            reviewType,
            reviewTypeLabel: getReviewTypeLabel(reviewType)
        }));
        
        allFindings.push(...findingsWithType);
        
        // Track summaries
        reviewSummaries[reviewType] = analysis.summary;
        
        // Sum up severity counts
        Object.keys(totalSeverity).forEach(sev => {
            totalSeverity[sev] += analysis.severity[sev] || 0;
        });
    });
    
    // Sort findings by severity
    const severityOrder = { critical: 4, high: 3, medium: 2, low: 1 };
    allFindings.sort((a, b) => 
        (severityOrder[b.severity] || 0) - (severityOrder[a.severity] || 0)
    );
    
    // Generate report
    const report = {
        timestamp: new Date().toISOString(),
        summary: {
            totalFindings: allFindings.length,
            totalCritical: totalSeverity.critical,
            totalHigh: totalSeverity.high,
            totalMedium: totalSeverity.medium,
            totalLow: totalSeverity.low
        },
        reviewSummaries,
        findings: allFindings,
        recommendations: generateRecommendations(allFindings, totalSeverity)
    };
    
    // Output based on format
    switch (format) {
        case 'json':
            console.log(JSON.stringify(report, null, 2));
            break;
            
        case 'markdown':
            outputMarkdownReport(report);
            break;
            
        case 'console':
        default:
            outputConsoleReport(report);
            break;
    }
    
    // Save to file if requested
    if (saveToFile) {
        const timestamp = new Date().toISOString().replace(/[:.]/g, '-');
        const reportPath = path.join(process.cwd(), 'docs', 'superpowers', 'reviews', `aggregate-review-${timestamp}.json`);
        
        // Ensure directory exists
        const reportDir = path.dirname(reportPath);
        if (!fs.existsSync(reportDir)) {
            fs.mkdirSync(reportDir, { recursive: true });
        }
        
        fs.writeFileSync(reportPath, JSON.stringify(report, null, 2));
        console.log(`\n💾 Detailed report saved to: ${reportPath}`);
    }
    
    return report;
}

// Get human-readable review type labels
function getReviewTypeLabel(reviewType) {
    const labels = {
        correctness: 'Correctness',
        architecture: 'Architecture',
        styleRules: 'Style Rules',
        performanceReliability: 'Performance & Reliability',
        regressionHistory: 'Regression & History'
    };
    
    return labels[reviewType] || reviewType;
}

// Generate recommendations based on findings
function generateRecommendations(findings, severityTotals) {
    const recommendations = [];
    
    // Critical issues recommendations
    if (severityTotals.critical > 0) {
        recommendations.push({
            priority: 'critical',
            action: '🚨 IMMEDIATE ACTION REQUIRED',
            description: `${severityTotals.critical} critical issues must be resolved before deployment`,
            nextSteps: [
                'Stop current deployment process',
                'Fix all critical issues immediately',
                'Re-run code review after fixes',
                'Conduct thorough testing'
            ]
        });
    }
    
    // High priority recommendations
    if (severityTotals.high > 5) {
        recommendations.push({
            priority: 'high',
            action: '⚠️ REVIEW REQUIRED',
            description: `${severityTotals.high} high-priority issues need attention`,
            nextSteps: [
                'Address high-priority issues before merge',
                'Consider pair programming for complex fixes',
                'Update tests to cover identified gaps',
                'Document any accepted technical debt'
            ]
        });
    }
    
    // Quality improvement recommendations
    if (severityTotals.medium > 10) {
        recommendations.push({
            priority: 'medium',
            action: '💡 QUALITY IMPROVEMENT',
            description: `${severityTotals.medium} medium-priority issues identified`,
            nextSteps: [
                'Plan refactoring session to address issues',
                'Consider adding linting rules',
                'Update team coding standards',
                'Schedule technical debt reduction sprint'
            ]
        });
    }
    
    // Code quality recommendations
    if (severityTotals.low > 20) {
        recommendations.push({
            priority: 'low',
            action: 'ℹ️ CODE QUALITY',
            description: `${severityTotals.low} low-priority improvements suggested`,
            nextSteps: [
                'Address during regular refactoring',
                'Consider automation tools',
                'Update documentation and examples',
                'Review team practices and guidelines'
            ]
        });
    }
    
    // Overall health recommendations
    const totalIssues = Object.values(severityTotals).reduce((a, b) => a + b, 0);
    if (totalIssues === 0) {
        recommendations.push({
            priority: 'success',
            action: '✅ EXCELLENT CODE QUALITY',
            description: 'No issues found across all review lanes',
            nextSteps: [
                'Proceed with confidence',
                'Consider this as a best practice example',
                'Share success patterns with team',
                'Maintain current quality standards'
            ]
        });
    } else if (totalIssues < 5) {
        recommendations.push({
            priority: 'good',
            action: '✨ GOOD CODE QUALITY',
            description: 'Minimal issues found - good work!',
            nextSteps: [
                'Address remaining issues as time permits',
                'Continue current development practices',
                'Consider documenting successful patterns'
            ]
        });
    }
    
    return recommendations;
}

// Output console report
