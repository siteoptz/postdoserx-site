    console.log('=' .repeat(60));
    console.log(`Report Generated: ${new Date(report.timestamp).toLocaleString()}`);
    console.log('');
    
    // Overall summary
    console.log('📈 OVERALL SUMMARY');
    console.log('-' .repeat(30));
    console.log(`Total Findings: ${report.summary.totalFindings}`);
    console.log(`🚨 Critical: ${report.summary.totalCritical}`);
    console.log(`⚠️  High: ${report.summary.totalHigh}`);
    console.log(`💡 Medium: ${report.summary.totalMedium}`);
    console.log(`ℹ️  Low: ${report.summary.totalLow}`);
    console.log('');
    
    // Review lane breakdown
    console.log('🔍 REVIEW LANE BREAKDOWN');
    console.log('-' .repeat(30));
    
    Object.entries(report.reviewSummaries).forEach(([type, summary]) => {
        const label = getReviewTypeLabel(type);
        const total = summary.totalIssues || 0;
        const critical = summary.criticalIssues || 0;
        const high = summary.highIssues || 0;
        
        const status = critical > 0 ? '🚨' : high > 0 ? '⚠️' : total > 0 ? '💡' : '✅';
        console.log(`${status} ${label}: ${total} issues (${critical}C, ${high}H)`);
    });
    console.log('');
    
    // Top critical/high issues
    const criticalFindings = report.findings.filter(f => f.severity === 'critical');
    const highFindings = report.findings.filter(f => f.severity === 'high');
    
    if (criticalFindings.length > 0) {
        console.log('🚨 CRITICAL ISSUES (MUST FIX)');
        console.log('-' .repeat(30));
        criticalFindings.slice(0, 5).forEach((finding, index) => {
            console.log(`${index + 1}. [${finding.reviewTypeLabel}] ${finding.finding}`);
            console.log(`   File: ${finding.file}:${finding.line}`);
            console.log(`   Fix: ${finding.recommendation}`);
            console.log('');
        });
        
        if (criticalFindings.length > 5) {
            console.log(`   ... and ${criticalFindings.length - 5} more critical issues\n`);
        }
    }
    
    if (highFindings.length > 0) {
        console.log('⚠️  HIGH PRIORITY ISSUES');
        console.log('-' .repeat(30));
        highFindings.slice(0, 3).forEach((finding, index) => {
            console.log(`${index + 1}. [${finding.reviewTypeLabel}] ${finding.finding}`);
            console.log(`   File: ${finding.file}:${finding.line}`);
            console.log(`   Fix: ${finding.recommendation}`);
            console.log('');
        });
        
        if (highFindings.length > 3) {
            console.log(`   ... and ${highFindings.length - 3} more high priority issues\n`);
        }
    }
    
    // Recommendations
    console.log('🎯 RECOMMENDATIONS');
    console.log('-' .repeat(30));
    report.recommendations.forEach(rec => {
        console.log(`${rec.action}`);
        console.log(`${rec.description}`);
        console.log('Next Steps:');
        rec.nextSteps.forEach(step => {
            console.log(`  • ${step}`);
        });
        console.log('');
    });
    
    // Code review status
    const blockingIssues = report.summary.totalCritical + report.summary.totalHigh;
    
    console.log('🔒 CODE REVIEW STATUS');
    console.log('-' .repeat(30));
    
    if (blockingIssues === 0) {
        console.log('✅ APPROVED - Ready for merge');
        console.log('   All critical and high-priority issues resolved');
        console.log('   Consider addressing medium/low priority items over time');
    } else {
        console.log('❌ BLOCKED - Cannot merge');
        console.log(`   ${blockingIssues} blocking issues must be resolved first`);
        console.log('   Re-run review after fixes are implemented');
    }
    
    console.log('');
}

