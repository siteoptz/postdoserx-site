// Main execution
async function main() {
    const args = process.argv.slice(2);
    const command = args[0];
    const format = args[1] || 'console';
    
    // Parse enforcement flags
    const isEnforcementMode = args.includes('--enforce');
    const enforceLanes = args.includes('--enforce-lanes') ? 
        args[args.indexOf('--enforce-lanes') + 1].split(',') : [];
    
    try {
        const reviews = await runAllReviews(args);
        
        switch (command) {
            case '--summary-only':
                // Quick summary without detailed findings
                const summaryReport = generateAggregateReport(reviews, { 
                    saveToFile: false, 
                    format: 'console' 
                });
                
                // Check for enforcement in summary mode
                if (isEnforcementMode) {
                    const blockingResult = checkEnforcementRules(summaryReport, enforceLanes);
                    process.exit(blockingResult.exitCode);
                }
                break;
                
            case '--json':
                const jsonReport = generateAggregateReport(reviews, { 
                    saveToFile: true, 
                    format: 'json' 
                });
                
                if (isEnforcementMode) {
                    const blockingResult = checkEnforcementRules(jsonReport, enforceLanes);
                    process.exit(blockingResult.exitCode);
                }
                break;
                
            case '--markdown':
                generateAggregateReport(reviews, { 
                    saveToFile: true, 
                    format: 'markdown' 
                });
                break;
                
            default:
                const fullReport = generateAggregateReport(reviews, { 
                    saveToFile: true, 
                    format: format 
                });
                
                // Enforcement mode logic
                if (isEnforcementMode) {
                    const blockingResult = checkEnforcementRules(fullReport, enforceLanes);
                    
                    console.log('\n📊 ENFORCEMENT RESULT');
                    console.log('-'.repeat(30));
                    console.log(blockingResult.message);
                    
                    if (blockingResult.exitCode === 2) {
                        console.log('\n🚫 CODE REVIEW BLOCKED');
                        console.log('   Fix critical/high issues in enforced lanes before merge');
                    } else if (blockingResult.exitCode === 1) {
                        console.log('\n⚠️ CODE REVIEW WARNINGS');
                        console.log('   Address issues during regular development');
                    } else {
                        console.log('\n✅ CODE REVIEW PASSED');
                        console.log('   All enforced quality gates satisfied');
                    }
                    
                    process.exit(blockingResult.exitCode);
                } else {
                    // Legacy warn-only mode
                    const blockingIssues = fullReport.summary.totalCritical + fullReport.summary.totalHigh;
                    if (blockingIssues > 0) {
                        console.log(`\n🚫 Exiting with error code due to ${blockingIssues} blocking issues`);
                        process.exit(1);
                    } else {
                        console.log('\n✅ All checks passed!');
                        process.exit(0);
                    }
                }
        }
        
    } catch (error) {
        console.error(`❌ Aggregate review failed: ${error.message}`);
        process.exit(1);
    }
}

// Check enforcement rules for specific lanes
function checkEnforcementRules(report, enforceLanes) {
    if (enforceLanes.length === 0) {
        // No specific lanes enforced, use legacy logic
        const blockingIssues = report.summary.totalCritical + report.summary.totalHigh;
        return {
            exitCode: blockingIssues > 0 ? 1 : 0,
            message: blockingIssues > 0 ? 
                `${blockingIssues} blocking issues found (warn-only)` : 
                'No blocking issues found'
        };
    }
    
    let criticalBlocking = 0;
    let highBlocking = 0;
    let totalWarnings = 0;
    const blockingDetails = [];
    
    // Check each enforced lane
    enforceLanes.forEach(lane => {
        const review = report.reviewSummaries[lane];
        if (!review) {
            console.warn(`Warning: Review lane '${lane}' not found`);
            return;
        }
        
        const critical = review.criticalIssues || 0;
        const high = review.highIssues || 0;
        const medium = review.mediumIssues || 0;
        const low = review.lowIssues || 0;
        
        // STEP 3 enforcement: architecture and regression lanes only block on critical
        if (lane === 'architecture' || lane === 'regressionHistory') {
            criticalBlocking += critical;
            // High issues are warnings for these lanes in STEP 3
            totalWarnings += high + medium + low;
            
            if (critical > 0) {
                blockingDetails.push(`${lane}: ${critical}C (STEP 3: critical-only)`);
            }
        } else {
            // Other lanes (like correctness) continue with critical + high blocking
            criticalBlocking += critical;
            highBlocking += high;
            totalWarnings += medium + low;
            
            if (critical > 0 || high > 0) {
                blockingDetails.push(`${lane}: ${critical}C ${high}H`);
            }
        }
    });
    
    // Determine exit code and message
    if (criticalBlocking > 0 || highBlocking > 0) {
        return {
            exitCode: 2, // Blocking failure
            message: `ENFORCED lanes have ${criticalBlocking} critical, ${highBlocking} high issues\n   Blocking lanes: ${blockingDetails.join(', ')}`
        };
    } else if (totalWarnings > 0) {
        return {
            exitCode: 1, // Warnings only
            message: `Enforced lanes clean, ${totalWarnings} warnings in other areas`
        };
    } else {
        return {
            exitCode: 0, // Success
            message: `All enforced lanes (${enforceLanes.join(', ')}) passed quality gates`
        };
    }
}

// Only run if this file is executed directly
if (require.main === module) {
    main().catch(error => {
        console.error('Fatal error:', error);
        process.exit(1);
    });
}

module.exports = {
    runAllReviews,
    generateAggregateReport
};